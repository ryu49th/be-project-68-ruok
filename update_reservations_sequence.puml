' -- update reservation --
@startuml Update Reservation (PUT)

header VacQ Sequence Diagram
footer Page %page% of %lastpage%
title "Update Reservation (PUT)"

participant "Client" as client
participant "<<javascript>>\n:server" as server
participant "<<router>>\n:reservations" as routerRes
participant "<<controllers>>\n:reservations" as controllersRes
participant "<<model>>\n:Reservation" as modelRes
database "<<MongoDB>>\n:reservations" as ResDatabase

client->server ++: PUT /api/v1/reservations/:id
server->routerRes ++: app.use('/api/v1/reservations', reservations)
routerRes -> controllersRes ++: updateReservation(id, body, user)
controllersRes->modelRes ++: findById(id)
modelRes -> ResDatabase ++: findOne({_id:id})
ResDatabase --> modelRes --: reservation
controllersRes->controllersRes ++: check ownership/role
controllersRes->modelRes ++: findByIdAndUpdate(id, body,{new:true})
modelRes -> ResDatabase ++: findOneAndUpdate
ResDatabase --> modelRes --: updatedDoc
controllersRes<-- modelRes --: reservation
controllersRes->client --: 200 {success:true,data}

@enduml