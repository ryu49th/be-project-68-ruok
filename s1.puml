' -- rate working space --
@startuml Rate Working Space (POST)

header VacQ Sequence Diagram
footer Page %page% of %lastpage%
title "Rate Working Space (POST)"

participant "Client" as client
participant "<<javascript>>\n:server" as server
participant "<<router>>\n:workingspaces" as routerWS
participant "<<controllers>>\n:workingspaces" as controllersWS
participant "<<model>>\n:WorkingSpace" as modelWS
database "<<MongoDB>>\n:workingspaces" as WSDatabase

client->server ++: POST /api/v1/workingspaces/{id}/rating
server->routerWS ++: app.use('/api/v1/workingspaces', workingspaces)
routerWS -> controllersWS ++: addWorkingSpaceRating(req.params.id, req.body)
controllersWS->modelWS ++: findById(id)
modelWS --> WSDatabase ++: query
WSDatabase --> modelWS --: doc
modelWS --> controllersWS --: workingspace
controllersWS -> modelWS ++: update averageRating, totalReviews
modelWS --> WSDatabase ++: update
WSDatabase --> modelWS --: updatedDoc
modelWS --> controllersWS --: updated workspace
controllersWS->client --: 200 {success:true, data}

@enduml